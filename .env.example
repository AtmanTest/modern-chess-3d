# ─── Base de données Supabase ───
# Obtenues depuis https://supabase.com/dashboard/project/[id]/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIs...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIs...

# ─── Socket.IO ───
# URL du serveur Socket.IO (en prod : même domaine que Next.js)
NEXT_PUBLIC_SOCKET_URL=

# ─── OAuth (GitHub + Google) ───
# Configurés dans Supabase Dashboard > Auth > Providers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── Render ───
# Webhook deploy (dans Render Dashboard > Service > Deploy Hooks)
RENDER_DEPLOY_HOOK_URL=

# ─── App ───
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
